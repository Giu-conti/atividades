using System;

namespace atividades
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("Exercício 1");

            Console.WriteLine("Me entregu  o número de eleitores");
            int eleitores = int.Parse(Console.ReadLine());

            Console.WriteLine("Me entregue o número de votos brancos:");
            int brancos = int.Parse(Console.ReadLine());

            Console.WriteLine("Me entregue o número de votos nulos:");
            int nulos = int.Parse(Console.ReadLine());

            Console.WriteLine("Me entregue o número de votos válidos:");
            int validos = int.Parse(Console.ReadLine());

            double porcentagemBranco = ((double)brancos / eleitores * 100);
            double porcentagemNulos = ((double)nulos / eleitores * 100);
            double porcentagemValidos = ((double)validos / eleitores * 100);
            
            Console.WriteLine("A porcentagem dos votos brancos é:" + porcentagemBranco + "%");
            Console.WriteLine("A porcentagem dos votos brancos é:" + porcentagemNulos + "%");
            Console.WriteLine("A porcentagem dos votos brancos é:" + porcentagemValidos + "%");



        }
    }
}
